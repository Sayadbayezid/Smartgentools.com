# ========================================
# APPLICATION CONFIGURATION
# ========================================

NODE_ENV=development
PORT=3000

# ========================================
# DATABASE CONFIGURATION
# ========================================

# MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/facebook-automation
MONGO_USER=admin
MONGO_PASSWORD=your-secure-password

# ========================================
# REDIS CONFIGURATION
# ========================================

# Local Redis or Upstash (https://upstash.com/)
REDIS_URL=redis://localhost:6379
# For Upstash: redis://default:password@endpoint:port

# ========================================
# AUTHENTICATION
# ========================================

JWT_SECRET=your-very-secure-jwt-secret-key-minimum-32-characters
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRY=30d

# ========================================
# FACEBOOK AUTOMATION
# ========================================

# Encryption key for storing Facebook cookies (32 characters)
FACEBOOK_COOKIES_ENCRYPTION_KEY=your-encryption-key-32-characters-long

# Playwright browser settings
HEADLESS=true
MAX_CONCURRENT_BROWSERS=5
PLAYWRIGHT_TIMEOUT=30000
BROWSER_ARGS=--no-sandbox,--disable-setuid-sandbox

# ========================================
# LOGGING & MONITORING
# ========================================

LOG_LEVEL=info
# Options: error, warn, info, debug

SENTRY_DSN=
# Leave empty to disable error reporting

# ========================================
# EXTERNAL SERVICES
# ========================================

# Email service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@smartgentools.com

# ========================================
# FRONTEND CONFIGURATION
# ========================================

REACT_APP_API_URL=http://localhost:3000/api
REACT_APP_WS_URL=ws://localhost:3000
REACT_APP_APP_NAME=Smartgentools
REACT_APP_VERSION=1.0.0

# ========================================
# GOOGLE OAUTH (OPTIONAL)
# ========================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ========================================
# DEPLOYMENT
# ========================================

# For Railway.app / Render
DATABASE_URL=${MONGO_URI}

# For Vercel / Netlify (Frontend)
VITE_API_URL=https://api.smartgentools.com
VITE_WS_URL=wss://api.smartgentools.com

# ========================================
# RATE LIMITING & SECURITY
# ========================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ========================================
# FEATURE FLAGS
# ========================================

ENABLE_COMMENT_AUTOMATION=true
ENABLE_GROUP_SCHEDULING=false
ENABLE_ANALYTICS=true
